{
    "name": "fastify-backend",
    "version": "1.0.0",
    "description": "Minimal Fastify backend with health check",
    "main": "dist/server.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/server.js",
        "dev": "dotenv -e config/.dev.env -- nodemon --watch src --ext ts --exec ts-node src/server.ts"
    },
    "dependencies": {
        "@fastify/mongodb": "^9.0.2",
        "@fastify/swagger": "^9.7.0",
        "@fastify/swagger-ui": "^5.2.5",
        "@sinclair/typebox": "^0.34.49",
        "fastify": "^5.8.4",
        "fastify-plugin": "^5.1.0"
    },
    "devDependencies": {
        "@types/node": "^20.10.0",
        "dotenv-cli": "^7.4.2",
        "nodemon": "^3.1.14",
        "ts-node": "^10.9.0",
        "typescript": "^5.3.0"
    }
}
